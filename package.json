{
  "name": "@trimble-oss/openapi-spectral-rules",
  "version": "0.0.1",
  "description": "This repository contains Spectral rules for linting Trimble OpenAPI specification documents. These rules are a companion to the Trimble Web API Standards.",
  "main": "spectral.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "jest",
    "lint-petstore-v3": "spectral lint examples/v3.0/petstore.yaml --ruleset spectral-r2026.1.yaml",
    "lint-petstore-v3-json": "spectral lint examples/v3.0/petstore.json --ruleset spectral-r2026.1.yaml",
    "lint-petstore-v3:r2023.1": "spectral lint examples/v3.0/petstore.yaml --ruleset spectral-r2023.1.yaml",
    "lint-petstore-v3:r2026.1": "spectral lint examples/v3.0/petstore.yaml --ruleset spectral-r2026.1.yaml",
    "lint-petstore-v3:auto": "node scripts/lint-by-standard-version.js examples/v3.0/petstore.yaml",
    "lint-r2023.1": "node scripts/lint-by-standard-version.js --version r2023.1",
    "lint-r2026.1": "node scripts/lint-by-standard-version.js --version r2026.1",
    "lint-auto": "node scripts/lint-by-standard-version.js",
    "lint-all": "npm run lint-petstore-v3 && npm run lint-petstore-v3-json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trimble-oss/openapi-spectral-rules.git"
  },
  "keywords": [
    "OpenAPI",
    "Spectral"
  ],
  "author": "Jeff Bendixsen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/trimble-oss/openapi-spectral-rules/issues"
  },
  "homepage": "https://github.com/trimble-oss/openapi-spectral-rules#readme",
  "devDependencies": {
    "@stoplight/spectral-core": "^1.21.0",
    "@stoplight/spectral-formats": "^1.8.2",
    "@stoplight/spectral-functions": "^1.10.1",
    "@stoplight/spectral-ruleset-migrator": "^1.11.3",
    "@stoplight/spectral-rulesets": "^1.22.0",
    "jest": "^30.3.0"
  }
}
